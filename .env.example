# SQLite database path (relative to apps/web or absolute)
DATABASE_URL=./data/mxwatch.db

# 32-char secret for better-auth + encrypting alert channel configs
MXWATCH_SECRET=change-me-to-a-32-character-string

# Port for DMARC report SMTP listener (2525 for non-root)
SMTP_PORT=2525

# Public URL of the app
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Outbound SMTP for sending email alerts
ALERT_SMTP_HOST=smtp.example.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASS=
ALERT_SMTP_FROM=mxwatch@example.com

# Google Postmaster Tools integration (optional)
# Create an OAuth Client ID in Google Cloud Console with the Gmail Postmaster Tools API
# enabled, add {NEXT_PUBLIC_APP_URL}/api/oauth/google/callback as an authorised redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override; defaults to {NEXT_PUBLIC_APP_URL}/api/oauth/google/callback
GOOGLE_OAUTH_REDIRECT_URL=

# Cloud mode (exposes billing UI + Lemon Squeezy integration).
# Leave unset or 0 on self-hosted deployments.
MXWATCH_CLOUD=

# Lemon Squeezy billing (only required when MXWATCH_CLOUD=1).
# Create API key + webhook secret in Lemon Squeezy dashboard.
# Webhook URL to register: {NEXT_PUBLIC_APP_URL}/api/webhooks/lemon
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_SOLO_VARIANT_ID=
LEMONSQUEEZY_TEAMS_VARIANT_ID=
