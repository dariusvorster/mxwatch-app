# SQLite database path (relative to apps/web or absolute)
DATABASE_URL=./data/mxwatch.db

# 32-char secret for better-auth + encrypting alert channel configs
MXWATCH_SECRET=change-me-to-a-32-character-string

# Port for DMARC report SMTP listener (2525 for non-root)
SMTP_PORT=2525

# Public URL of the app
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Outbound SMTP for sending email alerts
ALERT_SMTP_HOST=smtp.example.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASS=
ALERT_SMTP_FROM=mxwatch@example.com

# Google Postmaster Tools integration (optional)
# Create an OAuth Client ID in Google Cloud Console with the Gmail Postmaster Tools API
# enabled, add {NEXT_PUBLIC_APP_URL}/api/oauth/google/callback as an authorised redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override; defaults to {NEXT_PUBLIC_APP_URL}/api/oauth/google/callback
GOOGLE_OAUTH_REDIRECT_URL=

# Cloud mode (exposes billing UI + Lemon Squeezy integration).
# Leave unset or 0 on self-hosted deployments.
MXWATCH_CLOUD=

# Lemon Squeezy billing (only required when MXWATCH_CLOUD=1).
# Create API key + webhook secret in Lemon Squeezy dashboard.
# Webhook URL to register: {NEXT_PUBLIC_APP_URL}/api/webhooks/lemon
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_SOLO_VARIANT_ID=
LEMONSQUEEZY_TEAMS_VARIANT_ID=

# Litestream — continuous SQLite backup to Cloudflare R2 (recommended for production)
# Create an R2 bucket + API token (Object Read & Write) in the Cloudflare dashboard.
LITESTREAM_R2_BUCKET=
LITESTREAM_R2_ACCESS_KEY_ID=
LITESTREAM_R2_SECRET_ACCESS_KEY=
LITESTREAM_R2_ENDPOINT=
# e.g. https://<account-id>.r2.cloudflarestorage.com

# Logging (Phase 8)
# Minimum level to persist to app_logs and the NDJSON file.
# debug | info | warn | error
LOG_LEVEL=info
# Directory inside the container for rotated NDJSON files. The Docker compose
# config pins this to the data volume — change only if you mount a dedicated
# logs volume.
LOG_DIR=/data/logs
# How many days of rotated files + SQLite log rows to retain.
LOG_RETENTION_DAYS=30

# Webhook signature verification (integrations spec)
# Set per provider you use — endpoint returns 503 until configured.
MXWATCH_WEBHOOK_RESEND_SECRET=
# Resend dashboard → Webhooks → 'whsec_...' signing secret.

MXWATCH_WEBHOOK_MAILGUN_SIGNING_KEY=
# Mailgun dashboard → Sending → Webhooks → HTTP webhook signing key.

MXWATCH_WEBHOOK_SENDGRID_PUBKEY=
# SendGrid Event Webhook settings → Signed Event Webhook → base64 DER public key.

MXWATCH_WEBHOOK_POSTMARK_BASIC_AUTH=
# 'user:password' that Postmark sends in the Authorization header.
# Configure the same creds in Postmark's webhook URL.


# Delist assistant (cloud-only AI draft — integrations spec)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
